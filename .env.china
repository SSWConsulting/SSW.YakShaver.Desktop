# Region URL constants for the CHINA build.
#
# All values are MOCKS until real China infrastructure is wired up
# (Gitee, DashScope, China-hosted backend, etc.).
#
# This file is committed and contains no secrets. It is loaded AFTER .env at
# build/runtime; values here are authoritative for any keys they define so the
# china binary cannot accidentally inherit a global URL from a polluted .env.

BUILD_REGION=china

GITHUB_API_URL=https://mock.china.local/git
GITHUB_RELEASES_DOWNLOAD_BASE=https://mock.china.local/releases
AZURE_LOGIN_URL=https://mock.china.local/auth
YOUTUBE_WATCH_URL_BASE=https://mock.china.local/video?id=
YOUTUBE_THUMBNAIL_URL_BASE=https://mock.china.local/thumbs
MCP_GITHUB_COPILOT_URL=https://mock.china.local/mcp/git
MCP_ATLASSIAN_URL=https://mock.china.local/mcp/atlassian
