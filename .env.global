# Region URL constants for the GLOBAL build.
#
# This file is committed and contains no secrets. It is loaded AFTER .env at
# build/runtime; values here are authoritative for any keys they define so the
# china binary cannot accidentally inherit a global URL from a polluted .env.
#
# Per-environment secrets (PORTAL_API_URL, AZURE_TENANT_ID, IdentityServer config,
# AppInsights connection, etc.) live in .env (gitignored). See .env.example.

BUILD_REGION=global

GITHUB_API_URL=https://api.github.com
GITHUB_RELEASES_DOWNLOAD_BASE=https://github.com
AZURE_LOGIN_URL=https://login.microsoftonline.com
YOUTUBE_WATCH_URL_BASE=https://www.youtube.com/watch?v=
YOUTUBE_THUMBNAIL_URL_BASE=https://img.youtube.com/vi
MCP_GITHUB_COPILOT_URL=https://api.githubcopilot.com/mcp/
MCP_ATLASSIAN_URL=https://mcp.atlassian.com/v1/mcp

# YouTube URL parsing (used by youtube-url-utils.ts and renderer URL validators)
YOUTUBE_VALID_DOMAINS=youtube.com,www.youtube.com,m.youtube.com,youtu.be
YOUTUBE_SHORT_HOSTNAME=youtu.be
