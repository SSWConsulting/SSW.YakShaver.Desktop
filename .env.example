# Portal API Configuration
PORTAL_API_URL=http://localhost:7009/api

MCP_CALLBACK_PORT=8090
MCP_AUTH_TIMEOUT_MS=60000

# Azure AD Authentication
AZURE_ENTRA_APP_CLIENT_ID=your_AZURE_ENTRA_APP_CLIENT_ID_here
AZURE_TENANT_ID=your_AZURE_TENANT_ID_here
AZURE_AUTH_SCOPE=User.Read
AZURE_AUTH_CUSTOM_PROTOCOL=yakshaver-desktop-dev

# IdentityServer Authentication
IDENTITY_SERVER_URL=https://identityserver_url_here
IDENTITY_SERVER_CLIENT_ID=your_identityserver_client_here
IDENTITY_SERVER_SCOPE=openid,profile,email,ssw-yakshaver-api,offline_access
IDENTITY_SERVER_CUSTOM_PROTOCOL=yakshaver-desktop-dev

# YakShaver 360 (cloud sandbox)
# The SSW.YakShaver front-end that exposes /api/360/*. Leave unset in dev to use
# http://localhost:3000; MUST be set to the public deployment in production.
YAKSHAVER_360_BASE_URL=http://localhost:3000

# Application Insights (Telemetry)
APPLICATIONINSIGHTS_CONNECTION_STRING=
